server {
    listen 80;
    server_name fitness-business-tg.ru www.fitness-business-tg.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name fitness-business-tg.ru www.fitness-business-tg.ru;

    # SSL сертификаты (установятся автоматически через certbot)
    ssl_certificate /etc/letsencrypt/live/fitness-business-tg.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/fitness-business-tg.ru/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Корневая директория
    root /var/www/fitness-business-tg;
    index index.html;

    # Логи
    access_log /var/log/nginx/fitness-access.log;
    error_log /var/log/nginx/fitness-error.log;

    # Статические файлы
    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "public, max-age=86400";
        
        # Для Telegram WebApp
        add_header Content-Security-Policy "script-src 'self' https://telegram.org;";
        add_header X-Frame-Options "ALLOW-FROM https://telegram.org";
    }

    # API для бэкенда
    location /api/ {
        proxy_pass http://localhost:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        
        # Особые заголовки для Telegram
        proxy_set_header X-Telegram-Bot-Api-Secret-Token "ваш_секретный_токен";
    }

    # Статические файлы (кеширование)
    location /static/ {
        alias /var/www/fitness-business-tg/static/;
        expires 365d;
        access_log off;
        add_header Cache-Control "public";
    }

    # WebSocket для реальных обновлений
    location /ws/ {
        proxy_pass http://localhost:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Запрет доступа к скрытым файлам
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }
}
